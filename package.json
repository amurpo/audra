{
  "name": "audra-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "BASE_PATH=/audra/ npm run build",
    "preview": "vite preview",
    "preview:pages": "BASE_PATH=/audra/ vite preview",
    "deploy": "npm run build:pages && npx gh-pages -d dist"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/node": "^22.15.29",
    "@vitejs/plugin-react": "^4.5.1",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
